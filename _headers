/*
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(self), microphone=(), geolocation=()

/index.html
  Cache-Control: no-cache

/service-worker.js
  Cache-Control: no-cache

/manifest.json
  Cache-Control: no-cache

/*.png
  Cache-Control: public, max-age=86400
